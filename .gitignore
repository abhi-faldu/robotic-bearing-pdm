# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Dataset — never commit raw bearing data to git ───────────────────────────
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# ── Trained model artifacts ───────────────────────────────────────────────────
models/
*.pt
*.pth
*.ckpt
*.pkl
*.joblib

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem

# ── MLflow / experiment tracking ──────────────────────────────────────────────
mlruns/
mlartifacts/

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Docker ───────────────────────────────────────────────────────────────────
.docker/
